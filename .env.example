# Copy this file to .env and fill in real values:
#   cp .env.example .env
# Then edit .env with your secrets. NEVER commit .env (it is gitignored).

# --- PostgreSQL ---
POSTGRES_DB=wiki
POSTGRES_USER=wiki
# Generate a strong password, e.g.:
#   openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Cloudflare Tunnel ---
# Zero Trust > Networks > Tunnels > your tunnel > copy the token after `--token`.
# Point the tunnel's public hostname (viscous.wiki) at  http://caddy:80
CLOUDFLARE_TUNNEL_TOKEN=paste-your-tunnel-token-here

# --- Uploader / R2 ---
# The Wiki.js group whose members may upload/delete media:
UPLOAD_GROUP=Video Uploaders

# R2 S3 credentials (R2 > Manage API Tokens > Object Read & Write, scoped to the bucket).
# Account ID is the subdomain in your S3 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=viscous-media
# Public serving domain (the R2 custom domain you attached to the bucket):
R2_PUBLIC_BASE=https://media.viscous.wiki

# Storage cap in bytes (free tier is 10 GB). Uploads that would exceed this are refused.
# 10 GB = 10000000000. Lower it (e.g. 9500000000) for a safety margin.
R2_QUOTA_BYTES=10000000000
# Max size of a single upload in bytes (default 5 GiB):
MAX_UPLOAD_BYTES=5368709120

# --- Backups (Hugging Face) ---
# Private HF dataset repo id to store DB backups, e.g. yourname/viscous-wiki-backups
HF_REPO=your-username/viscous-wiki-backups
# Hugging Face access token with WRITE permission (keep secret):
HF_TOKEN=hf_your_write_token
# How many backups to keep (older ones are pruned automatically):
BACKUP_KEEP=14
# STRONGLY RECOMMENDED: encrypt dumps before upload. The DB holds password
# hashes and the wiki's signing key. Set a strong passphrase to enable AES-256.
# Store this passphrase somewhere safe — without it, backups can't be restored.
BACKUP_PASSPHRASE=
