# Copy this file to .env and fill in real values:
#   cp .env.example .env
# Then edit .env with your secrets. NEVER commit .env (it is gitignored).

# --- PostgreSQL ---
POSTGRES_DB=wiki
POSTGRES_USER=wiki
# Generate a strong password, e.g.:
#   openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Cloudflare Tunnel ---
# Cloudflare Zero Trust dashboard:
#   Networks > Tunnels > Create a tunnel > Cloudflared > name it > Save
#   Copy the token from the "Install connector" step (the string after `--token`).
CLOUDFLARE_TUNNEL_TOKEN=paste-your-tunnel-token-here
